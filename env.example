# ── OpenWeatherMap ─────────────────────────────────────────────────────────
# Get yours free at: https://home.openweathermap.org/users/sign_up
OWM_API_KEY=your_openweathermap_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eaweather
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── Email Alerts (Airflow SMTP / smtplib) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password   # Use App Password, NOT your real password
ALERT_EMAIL=alerts@yourdomain.com
